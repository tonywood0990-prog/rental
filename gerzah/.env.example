# ─────────────────────────────────────────────────────────────────
# GerZah (Гэр Зах) Environment Variables
# Copy this file to app/.env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# Supabase — find these in your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only, NEVER expose to client)
# Find in: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The public URL of your deployed site (used for redirects)
# Development: http://localhost:3000
# Production: https://your-app.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
